# F*cking Gorgeous - Environment Variables
# Copy this to .env and fill in your API key
# Only ONE is needed - the script auto-detects which to use

# Option 1: HuggingFace Inference API (FREE - FLUX Schnell + Stable Diffusion)
# Get yours at: https://huggingface.co/settings/tokens
HF_API_KEY=

# Option 2: Higgsfield API (has free credits)
# Get yours at: https://platform.higgsfield.ai/dashboard
# Format: key:secret
HIGGSFIELD_API_KEY=

# Option 3: OpenAI / DALL-E 3 (paid, ~$0.08/image HD)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
